{
  "name": "mongo-sink",
  "config": {
    "connector.class": "com.mongodb.kafka.connect.MongoSinkConnector",
    "tasks.max": "1",

    "topics": "weather,air_quality,weather.raw,bike_summary,road_disruption",


    "connection.uri": "mongodb+srv://user1:user1password@cluster0.tko1rud.mongodb.net/",
    "database": "bdg",
    "collection": "events",

    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false",

    "document.id.strategy": "com.mongodb.kafka.connect.sink.processor.id.strategy.PartialValueStrategy",
    "document.id.strategy.partial.value.projection.list": "city,provider_ts",
    "document.id.strategy.partial.value.projection.type": "AllowList",


    "writemodel.strategy": "com.mongodb.kafka.connect.sink.writemodel.strategy.ReplaceOneBusinessKeyStrategy",

    "max.num.retries": "3",
    "retries.defer.timeout": "5000"
  }
}
